# Codebuff / Freebuff 上游 Bearer token。
# 必填。来源是 HAR 或客户端请求里的 Authorization: Bearer <token>。
# 只填写 token 本体，不要带 "Bearer " 前缀。
# 多账号用英文逗号分隔；并发请求会自动分配到空闲账号。
# 多账号还会按一天 24 小时平均分时使用：N 个 token 时，每个 token 使用
# 24/N 小时后自动切换到下一个，日志会打印当前正在使用第几个 token。
# 示例：FREEBUFF_TOKEN=token-a,token-b,token-c
FREEBUFF_TOKEN=

# UNLIMITED 模型白名单，多个用英文逗号分隔。
# 仅在配置了多个 FREEBUFF_TOKEN 时生效。
# 白名单内的模型在当前时段 token 繁忙时允许回退到其他空闲 token。
# 其余模型（除唯一 premium 模型外）一律拒绝。
# 示例：FREEBUFF_UNLIMITED_MODEL=deepseek/deepseek-v4-flash,minimax/minimax-m3
FREEBUFF_UNLIMITED_MODEL=deepseek/deepseek-v4-flash

# 唯一允许的 premium 模型（每天 5 次/约 5 小时额度，pacific 午夜重置）。
# 只允许这一个 premium 模型；请求其他 premium 模型会被拒绝，避免切模型浪费额度。
FREEBUFF_PREMIUM_MODEL=moonshotai/kimi-k2.7-code

# premium 会话计费块长（秒）。上游按块阶梯计费，实测 6 分钟一块、每块 0.1。
FREEBUFF_SESSION_BLOCK_SECONDS=360

# premium 会话销毁提前量（秒）。在每个计费块边界前这么多秒进入“销毁窗口”，
# 空闲即删，确保 DELETE 在跨块前完成、不进入下一块多花 0.1。
FREEBUFF_DESTROY_LEAD_SECONDS=45

# 复用缓存会话时跳过确认 GET 的余量（秒）。免费会话硬活 1 小时（服务端给
# expiresAt），官方发消息也不查会话。若缓存会话距过期还剩 > 这个值，就直接复用、
# 省掉每请求 ~2s 的 get_session 确认往返；不足这个值才回退去确认。设 0 关闭（每次都确认）。
FREEBUFF_SESSION_REUSE_CONFIRM_MARGIN=300

# premium 额度统计的持久化文件（重启不丢）。
FREEBUFF_QUOTA_FILE=data/quota.json

# 多 token 分时调度所用的时区，固定 UTC 偏移（小时，不含夏令时）。
# 循环从该时区的 00:00 开始；例如 -7 让循环在 UTC+8 15:00 开始（对齐额度重置时刻）。
FREEBUFF_SCHEDULE_UTC_OFFSET=-7

# 本地 OpenAI-compatible API 的访问密钥。
# 可选。留空表示本地接口不校验 Authorization。
# 如果填写，例如 FREEBUFF_API_KEY=sk-local，调用本项目时需要带：
# Authorization: Bearer sk-local
FREEBUFF_API_KEY=

# Freebuff 上游 API 根地址
FREEBUFF_API_BASE_URL=https://www.codebuff.com

# 广告 provider 尝试顺序（留空则完全关闭广告）。
# 广告是纯遥测/伪装（聊天从不读广告结果），已全部改为后台 fire-and-forget，
# 不占首字延迟——对齐官方（官方广告本就是后台 60s 定时器，从不阻塞发送）。
# 保留广告是为了让请求看起来像真客户端（一直不拉广告可能被上游反滥用盯上）。
# 上游 /api/v1/ads 的 provider 仅接受 gravity|carbon（zeroclick 已下线，会返回 400）。
FREEBUFF_AD_PROVIDERS=gravity,carbon

# 每请求广告链（request_ad_chain）的最小间隔（秒），模拟官方 ~60s 定时器的频率，
# 避免每条消息都拉广告（那样反而不像真客户端、还徒增上游负载）。窗口内的请求
# 直接跳过拉广告。设 0 表示每请求都拉。建会话时的 waiting_room 广告不受此限。
FREEBUFF_AD_REFRESH_SECONDS=60

# 上游 HTTP 请求超时时间，单位秒。
# 流式对话的读取超时已单独放开，这里主要影响普通请求。
FREEBUFF_TIMEOUT=60

# 是否启用上游代理。
# false：所有上游请求直连，且不会读取系统 HTTP_PROXY / HTTPS_PROXY。
# true：所有上游请求都经过 FREEBUFF_PROXY_URL。
FREEBUFF_PROXY_ENABLED=false

# 上游代理地址。
# 支持 http://、https://、socks5://、socks5h://。
# 示例：http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
FREEBUFF_PROXY_URL=

# 调试模式。
# false：只输出关键运行日志。
# true：输出上游请求/响应、SSE 原始行、OpenAI 转换后 chunk、finalize 异常等详细信息。
FREEBUFF_DEBUG=false

# 日志级别。
# 常用值：DEBUG、INFO、WARNING、ERROR。
# 开启 FREEBUFF_DEBUG=true 时默认会使用 DEBUG。
FREEBUFF_LOG_LEVEL=INFO

# 日志中请求体/响应体最大打印字符数。
# 0 表示不截断；调试复杂问题时可设为 0。
FREEBUFF_LOG_BODY_CHARS=2000

# 是否启用彩色日志。
# true：按日志级别输出 ANSI 颜色。
# false：纯文本日志，适合写入文件或不支持 ANSI 的终端。
FREEBUFF_LOG_COLOR=true

# 服务监听地址。
# 默认 0.0.0.0，仅容器环境或需外部访问时保持默认。
# 本地测试建议设为 127.0.0.1。
FREEBUFF_HOST=0.0.0.0

# 服务监听端口。
# 默认 8000。
FREEBUFF_PORT=8000

# 模拟客户端设备信息：时区。
# HAR 中为 Asia/Shanghai。
FREEBUFF_TIMEZONE=Asia/Shanghai

# 模拟客户端设备信息：语言区域。
# HAR 中为 zh-CN。
FREEBUFF_LOCALE=zh-CN

# 模拟客户端设备信息：操作系统。
# HAR 中为 windows。
FREEBUFF_OS=windows
